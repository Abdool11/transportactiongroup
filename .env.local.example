# ─────────────────────────────────────────────────────────────────────────────
# TAG — transportactiongroup.co.za
# Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file to .env.local
#   2. Fill in every value below
#   3. NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key_here

# ── Admin Authentication ───────────────────────────────────────────────────────
# A long random string used to sign admin session JWTs.
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=replace_with_64_char_random_hex_string

# ── Resend (Transactional Email) ───────────────────────────────────────────────
# Found in: https://resend.com/api-keys
# Used for: enquiry notifications, contact form submissions
RESEND_API_KEY=re_...your_resend_key_here

# ── Site URL ───────────────────────────────────────────────────────────────────
# The public URL of this site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://transportactiongroup.co.za

# ── Port (optional, defaults to 3002) ─────────────────────────────────────────
PORT=3002
