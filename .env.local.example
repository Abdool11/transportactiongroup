# ─────────────────────────────────────────────────────────────────────────────
# TAG — transportactiongroup.co.za
# Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file to .env.local
#   2. Fill in every value below
#   3. NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Shared project for the full TAG ecosystem (TAG + GFA + BD)
NEXT_PUBLIC_SUPABASE_URL=https://khzctzixeghppwwnzsdq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME_your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_your_supabase_service_role_key

# ── Admin Authentication ───────────────────────────────────────────────────────
# Used to sign admin session JWTs. Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=REPLACE_ME_run_openssl_rand_-hex_32
# Default admin credentials for first login
ADMIN_EMAIL=durbanroadtransport@gmail.com
ADMIN_PASSWORD=changeme

# ── Resend (Transactional Email) ───────────────────────────────────────────────
# Found in: https://resend.com/api-keys
# Used for: enquiry notifications, contact form submissions
RESEND_API_KEY=REPLACE_ME_re_your_resend_key_here

# ── GFA Integration ────────────────────────────────────────────────────────────
# Used to fetch live pricing data from GFA for the TAG Academy page
GFA_PRICING_API_URL=https://www.greenfreightacademy.co.za/api/pricing

# ── Site URLs ──────────────────────────────────────────────────────────────────
# The public URLs of the ecosystem sites (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.transportactiongroup.com
NEXT_PUBLIC_GFA_URL=https://www.greenfreightacademy.co.za
NEXT_PUBLIC_BETTERDRIVER_URL=https://betterdriver.co.za
NEXT_PUBLIC_ZERO_AFRICA_URL=https://www.zeroafrica.org

# ── Port (optional, defaults to 3000) ─────────────────────────────────────────
PORT=3000
