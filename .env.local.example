# ── Admin Authentication ───────────────────────────────────────────────────────
# A long random string used to sign admin session JWTs.
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=replace_with_64_char_random_hex_string

# ── Resend (Transactional Email) ───────────────────────────────────────────────
# Found in: https://resend.com/api-keys
# Used for: enquiry notifications, contact form submissions
RESEND_API_KEY=re_...your_resend_key_here

# ── Site URL ───────────────────────────────────────────────────────────────────
# The public URL of this site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://transportactiongroup.co.za

# ── Port (optional, defaults to 3002) ─────────────────────────────────────────
PORT=3000
